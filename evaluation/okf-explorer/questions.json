{
  "schema": "okf-explorer-evaluation-suite.v1",
  "title": "UK Government APIs OKF Explorer Evaluation Suite",
  "description": "A 100-question browser evaluation suite for retrieval, display clarity, accessibility and GOV.UK-aligned publication quality in the OKF Explorer.",
  "rubric": {
    "retrieval": {
      "points": 35,
      "checks": [
        "query returns visible results or a meaningful empty state",
        "top results contain expected terms or expected route",
        "result count is visible",
        "selected record can be opened without stale context",
        "provider, record type, source and protocol are discoverable"
      ]
    },
    "display": {
      "points": 25,
      "checks": [
        "detail panel exposes title, summary and route",
        "licence, access model, contract status and confidence are visible when available",
        "metadata gaps are labelled as gaps rather than raw None/null values",
        "chips/facets/deep links support follow-on exploration",
        "loading and search state are visible and clear",
        "graph labels, arrows and relationship drawers preserve readability without overlapping the selected target"
      ]
    },
    "accessibility": {
      "points": 20,
      "checks": [
        "interactive controls have accessible names",
        "status updates use aria-live where appropriate",
        "keyboard-focusable controls are present for search, results and detail actions",
        "page uses landmarks and avoids empty buttons/links",
        "labels and controls do not overlap at the tested viewport"
      ]
    },
    "govuk": {
      "points": 20,
      "checks": [
        "language is plain and task-focused",
        "public-sector metadata is explicit about provenance, licence and access",
        "service-style actions are clear and predictable",
        "metadata quality claims are explained and not presented as assurance",
        "no secrets or credential values are displayed"
      ]
    }
  },
