{
  "schema": "okf-explorer-evaluation-suite.v1",
  "title": "GOV.UK CKAN OKF Evaluation Suite",
  "description": "A 100-question evaluation suite for the hosted GOV.UK CKAN large-corpus OKF bundle, using the same additive rubric as the UK Government APIs exemplar.",
  "target_bundle": "https://chris-page-gov.github.io/ai-engineering-lab-hackathon-london-2026/gov-ckan/okf-explorer.json",
  "rubric": {
    "retrieval": {
      "points": 35,
      "checks": [
        "Search or facet path returns the expected record family.",
        "Expected publisher, dataset, topic, format or resource terms are visible.",
        "The visible result count is plausible and not a stale previous query.",
        "A route or detail target is available for sharing and re-opening.",
        "Core metadata such as publisher, resource count, format or source is discoverable."
      ]
    },
    "display": {
      "points": 25,
      "checks": [
        "The detail card has a clear title, summary and route.",
        "Licence, access, source, resource and update metadata are visible or clearly marked as missing.",
        "Metadata gaps use reader-facing wording rather than raw null, None or undefined values.",
        "Follow-on actions such as Graph, Pin, Copy route and resource inspection are visible.",
        "Loading and search states are explicit and do not leave the user guessing."
      ]
    },
    "accessibility": {
      "points": 20,
      "checks": [
        "Buttons, links, inputs and graph targets have accessible names.",
        "Loading/search status is exposed through live regions where relevant.",
        "Keyboard focus targets are present for search, facets, results and detail actions.",
        "The page retains landmarks for header, navigation, main content and complementary panels.",
        "The tested viewport avoids obvious text, graph-label or card overlap."
      ]
    },
    "govuk": {
      "points": 20,
      "checks": [
        "Terminology follows clear public-service language.",
        "Publisher/source provenance is explicit enough for public-sector reuse.",
        "Licence and access status are shown without implying unsupported assurance.",
        "Controls are predictable service-style actions rather than decorative UI.",
        "No displayed URL or metadata leaks secrets, tokens, passwords or API keys."
      ]
    }
  },
