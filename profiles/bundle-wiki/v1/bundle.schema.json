{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chris-page-gov.github.io/okf-explorer/profile/bundle-wiki/v1/bundle.schema.json",
  "title": "OKF Bundle Wiki descriptor",
  "type": "object",
  "required": ["@context", "@id", "@type", "title", "description", "version", "status", "descriptor", "semanticDescriptor", "home", "profile", "publisher", "license"],
  "properties": {
    "@context": {
      "oneOf": [
        {"type": "string", "format": "uri"},
        {"type": "array", "minItems": 1}
      ]
    },
    "@id": {"type": "string", "format": "uri"},
    "@type": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"},
    "status": {"enum": ["experimental", "preview", "stable", "deprecated", "archived"]},
    "descriptor": {"$ref": "#/$defs/idObject"},
    "semanticDescriptor": {"$ref": "#/$defs/idObject"},
    "home": {"$ref": "#/$defs/idObject"},
    "profile": {"$ref": "#/$defs/idObject"},
    "publisher": {"$ref": "#/$defs/idObject"},
    "license": {"$ref": "#/$defs/idObject"}
  },
  "additionalProperties": true,
  "$defs": {
    "idObject": {
      "type": "object",
      "required": ["@id"],
      "properties": {"@id": {"type": "string", "format": "uri"}},
      "additionalProperties": true
    }
  }
}
