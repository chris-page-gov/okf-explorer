@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix okf: <https://chris-page-gov.github.io/okf-explorer/ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

okf:BundleShape
    a sh:NodeShape ;
    sh:targetClass okf:Bundle ;
    sh:nodeKind sh:IRI ;
    sh:property [ sh:path dcterms:title ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcterms:description ; sh:minCount 1 ] ;
    sh:property [ sh:path dcterms:conformsTo ; sh:minCount 1 ; sh:nodeKind sh:IRI ] ;
    sh:property [ sh:path dcterms:license ; sh:minCount 1 ; sh:nodeKind sh:IRI ] ;
    sh:property [ sh:path dcterms:publisher ; sh:minCount 1 ; sh:nodeKind sh:IRI ] .

okf:ConceptShape
    a sh:NodeShape ;
    sh:targetClass okf:Concept ;
    sh:nodeKind sh:IRI ;
    sh:property [ sh:path dcterms:title ; sh:minCount 1 ; sh:maxCount 1 ] ;
    sh:property [ sh:path dcterms:description ; sh:minCount 1 ] .
