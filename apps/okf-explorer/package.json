{
  "name": "@okf/explorer",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:pages": "PLAYWRIGHT_BASE_URL=https://chris-page-gov.github.io/okf-explorer/ playwright test",
    "test:e2e:headed": "playwright test --headed",
    "benchmark:search": "node ../../scripts/benchmark_static_search.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "cookie": "^0.7.2"
    }
  }
}
